{
  "name": "timer-keeper-extension",
  "version": "4.0.0",
  "description": "Timer Keeper - project time tracking extension for Adobe After Effects",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "tsc -b && vite build && node scripts/deploy.mjs",
    "package": "node scripts/package.mjs",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/google-sans-flex": "^5.2.3",
    "material-symbols": "^0.45.5",
    "react": "^19.2.7",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
